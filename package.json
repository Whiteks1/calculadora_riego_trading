{
  "name": "calculadora-riego-trading",
  "private": true,
  "version": "1.0.0",
  "description": "Pre-trade risk workbench and deterministic trade-plan exports.",
  "bin": {
    "trade-plan-cli": "./cli/trade-plan.js"
  },
  "scripts": {
    "dev": "node scripts/serve-static.js --port 4173 --host 127.0.0.1",
    "start": "npm run dev",
